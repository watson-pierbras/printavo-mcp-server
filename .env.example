# Printavo API Credentials
# Get your API token from Printavo > My Account > API
PRINTAVO_EMAIL=you@yourbusiness.com
PRINTAVO_API_TOKEN=your_printavo_api_token_here

# MCP Server Authentication
# This key protects the /mcp endpoint. Use a strong random secret.
# Perplexity will send this as: Authorization: Bearer <MCP_API_KEY>
MCP_API_KEY=generate_a_strong_random_secret_here

# Server Port (optional, defaults to 3000)
PORT=3000
